# Postgres connection string. On Railway this is provided automatically by the
# Postgres plugin as DATABASE_URL — you don't set it by hand there.
DATABASE_URL=postgresql://user:pass@localhost:5432/brfitness

# Optional. If set, requests must send a matching x-app-secret header.
# Leave unset to make the search endpoint open.
APP_SECRET=

PORT=3000

# Optional query safeguards. The application uses these defaults if omitted.
DB_STATEMENT_TIMEOUT_MS=2500
DB_QUERY_TIMEOUT_MS=3000
